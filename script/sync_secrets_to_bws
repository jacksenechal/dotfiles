#!/usr/bin/env bash
set -euo pipefail

PROJECT_NAME=${DOTFILES_BWS_PROJECT_NAME:-dotfiles}
DEFAULT_TOKEN_FILE="$HOME/.config/bitwarden-sm/access-token"
LEGACY_TOKEN_FILE="$HOME/.config/keys/BWS_ACCESS_TOKEN"
TOKEN_FILE=${BWS_ACCESS_TOKEN_FILE:-}

if [[ -z "$TOKEN_FILE" ]]; then
  if [[ -f "$DEFAULT_TOKEN_FILE" ]]; then
    TOKEN_FILE="$DEFAULT_TOKEN_FILE"
  else
    TOKEN_FILE="$LEGACY_TOKEN_FILE"
  fi
fi

if [[ -z "${BWS_ACCESS_TOKEN:-}" ]]; then
  if [[ ! -f "$TOKEN_FILE" ]]; then
    echo "Bitwarden access token not found." >&2
    echo "Set BWS_ACCESS_TOKEN or create $DEFAULT_TOKEN_FILE (recommended) or $LEGACY_TOKEN_FILE." >&2
    exit 1
  fi
  export BWS_ACCESS_TOKEN
  BWS_ACCESS_TOKEN="$(tr -d '\n' < "$TOKEN_FILE")"
fi

if [[ -n "${BWS_SERVER_BASE:-}" ]]; then
  export BWS_SERVER_BASE
fi

find_bws() {
  if [[ -n "${BWS_BIN:-}" && -x "${BWS_BIN}" ]]; then
    printf '%s\n' "$BWS_BIN"
    return
  fi
  if command -v bws >/dev/null 2>&1; then
    command -v bws
    return
  fi
  if [[ -x "$HOME/.local/bin/bws" ]]; then
    printf '%s\n' "$HOME/.local/bin/bws"
    return
  fi
  echo "Unable to find bws. Run the ansible playbook once or install bws manually." >&2
  exit 1
}

BWS_BIN="$(find_bws)"
export BWS_BIN

project_json="$($BWS_BIN project list --output json)"
project_id="$(python3 - <<'PY' "$PROJECT_NAME" "$project_json"
import json, sys
name = sys.argv[1]
projects = json.loads(sys.argv[2])
for project in projects:
    if project.get('name') == name:
        print(project['id'])
        break
PY
)"

if [[ -z "$project_id" ]]; then
  echo "Creating Bitwarden project '$PROJECT_NAME'" >&2
  project_id="$($BWS_BIN project create "$PROJECT_NAME" --output json | python3 -c 'import json,sys; print(json.load(sys.stdin)["id"])')"
fi

secret_json="$($BWS_BIN secret list "$project_id" --output json)"
export EXISTING_SECRETS_JSON="$secret_json"

lookup_secret_id() {
  local key="$1"
  python3 - <<'PY' "$key"
import json, os, sys
key = sys.argv[1]
for secret in json.loads(os.environ.get('EXISTING_SECRETS_JSON', '[]')):
    if secret.get('key') == key:
        print(secret['id'])
        break
PY
}

collect_files() {
  find "$HOME/.ssh" -maxdepth 1 -type f \( -name 'id*' -o -name 'config*' \) 2>/dev/null | sort
  find "$HOME/.config/keys" -maxdepth 1 -type f ! -name 'BWS_ACCESS_TOKEN' 2>/dev/null | sort
}

mapfile -t files < <(collect_files)
if [[ ${#files[@]} -eq 0 ]]; then
  echo "No candidate secret files found in ~/.ssh or ~/.config/keys" >&2
  exit 1
fi

for file in "${files[@]}"; do
  rel="${file#"$HOME"/}"
  if [[ "$rel" == "$file" ]]; then
    echo "Skipping non-home file: $file" >&2
    continue
  fi

  key="file:$rel"
  mode="$(stat -c '%a' "$file")"
  value="$(<"$file")"

  if [[ -z "$value" ]]; then
    echo "Skipping empty file $rel" >&2
    continue
  fi

  secret_id="$(lookup_secret_id "$key")"

  if [[ -n "$secret_id" ]]; then
    echo "Updating $rel" >&2
    "$BWS_BIN" secret edit "$secret_id" \
      "--key=$key" \
      "--value=$value" \
      "--note=$mode" \
      "--project-id=$project_id" \
      --output none >/dev/null
  else
    echo "Creating $rel" >&2
    "$BWS_BIN" secret create \
      --note "$mode" \
      --output none \
      -- "$key" "$value" "$project_id" >/dev/null
  fi

done

echo "Synced ${#files[@]} files to Bitwarden project '$PROJECT_NAME'." >&2
